# ============================================================
#  zapret2-tui — файл секретов (.env)
#  НИКОГДА не загружай этот файл на GitHub!
#  Файл .gitignore уже защищает его от случайной загрузки.
# ============================================================

# Выбор AI провайдера: claude | openai | none
AI_PROVIDER=claude

# --- Claude (Anthropic) ---
# Получить ключ: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- ChatGPT (OpenAI) ---
# Получить ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Модели (можно изменить) ---
# Claude модели: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI модели: gpt-4o, gpt-4o-mini, gpt-4-turbo
OPENAI_MODEL=gpt-4o
